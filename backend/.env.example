PORT=3001
# If 3001 is taken, the API tries 3002, 3003, etc.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
DATABASE_PATH=./data/habit-buddies.sqlite
DATABASES_PATH=./databases
PASSWORD_RESET_EXPIRES_MINUTES=60
FRONTEND_URL=http://localhost:3000
ADMIN_EMAIL=admin@habitbuddies.com
ADMIN_PASSWORD=adminpassword123

# Supabase Postgres
# Use port 6543 (pooler) if direct port 5432 times out on your network (IPv6-only host).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres

# Supabase API (service_role key — backend only, never expose to frontend)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Copy the anon public key from the same API page into frontend/.env as NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_ANON_KEY=

# Daily.co (voice/video calls — backend only)
DAILY_API_KEY=

# Storage: single public bucket with folders
SUPABASE_STORAGE_BUCKET=storage
SUPABASE_AVATARS_FOLDER=avatars
SUPABASE_GROUP_IMAGES_FOLDER=group-images
